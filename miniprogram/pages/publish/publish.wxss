/* ===== 发布商品 ===== */
page { background: #f8f8f8; }

.upload-section {
  margin-bottom: 32rpx;
}
.section-label {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
  font-weight: 600;
}
.section-hint {
  font-size: 22rpx;
  color: #bbb;
  display: block;
  margin-bottom: 16rpx;
}

.upload-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.upload-item {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.upload-preview {
  width: 100%;
  height: 100%;
}

.upload-remove {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.55);
  color: #fff;
  border-radius: 50%;
  text-align: center;
  line-height: 40rpx;
  font-size: 28rpx;
  backdrop-filter: blur(4rpx);
}

.upload-btn {
  width: 180rpx;
  height: 180rpx;
  border: 4rpx dashed #ddd;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
  transition: all 0.2s;
}

.upload-btn:active {
  background: #f0f0f0;
  border-color: #07c160;
}

.upload-plus {
  font-size: 52rpx;
  color: #bbb;
  line-height: 1;
}

.upload-text {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 8rpx;
}

.picker-value {
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: #333;
  position: relative;
}

.picker-value.placeholder {
  color: #bbb;
}

.picker-value::after {
  content: '›';
  position: absolute;
  right: 24rpx;
  color: #ccc;
  font-size: 36rpx;
  top: 50%;
  transform: translateY(-50%);
}

/* 价格输入 */
.price-input-wrap {
  display: flex;
  align-items: center;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 0 28rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.price-input-wrap:focus-within {
  border-color: #07c160;
  background: #fff;
  box-shadow: 0 0 0 4rpx rgba(7, 193, 96, 0.1);
}

.price-currency {
  font-size: 32rpx;
  color: #f60;
  font-weight: 700;
  margin-right: 8rpx;
}

.price-input {
  flex: 1;
  background: transparent !important;
  padding-left: 0 !important;
  border: none !important;
  box-shadow: none !important;
  font-size: 36rpx;
  font-weight: 600;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 8rpx;
  display: block;
}

/* 确保输入文字可见 */
.input-field {
  color: #333 !important;
}

.input-field::placeholder {
  color: #bbb !important;
}

.price-input {
  color: #f60 !important;
  font-weight: 700 !important;
}

.textarea {
  color: #333 !important;
}

.textarea {
  height: 200rpx;
  line-height: 1.6;
  resize: none;
}

/* 输入框包装器 */
.input-wrap {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 0 28rpx;
  border: 2rpx solid #ddd;
}

.input-wrap input {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  color: #000000;
  background: transparent;
  border: none;
  outline: none;
}

.input-preview {
  display: block;
  color: #07c160;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.input-hint {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 8rpx;
  display: block;
}

.price-input {
  flex: 1;
  height: 80rpx;
  font-size: 36rpx;
  font-weight: 600;
  color: #000000;
  background: transparent;
  border: none;
  outline: none;
}

.btn-submit {
  margin: 16rpx 24rpx 40rpx;
  background: linear-gradient(135deg, #07c160, #05a34e);
  color: #fff;
  border-radius: 50rpx;
  padding: 26rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(7, 193, 96, 0.3);
}

.btn-submit:active { opacity: 0.9; }
.btn-submit.disabled { opacity: 0.5; box-shadow: none; }
