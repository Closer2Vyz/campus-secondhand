/* ===== 首页样式 ===== */
page { background: #f8f8f8; }

/* ===== 搜索栏 ===== */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  gap: 16rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 50rpx;
  padding: 0 24rpx;
  border: 2rpx solid #eee;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  color: #333;
  background: transparent;
  border: none;
}

.search-clear {
  font-size: 28rpx;
  color: #bbb;
  padding: 8rpx;
}

.search-btn {
  font-size: 28rpx;
  color: #07c160;
  font-weight: 500;
  white-space: nowrap;
}

/* 排序 */
.section-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.sort-options {
  display: flex;
  gap: 8rpx;
}

.sort-option {
  font-size: 24rpx;
  color: #999;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  border: 2rpx solid #eee;
}

.sort-option.active {
  color: #07c160;
  border-color: #07c160;
  background: #e8f5e9;
}

/* Banner 轮播 */
.banner-swiper {
  height: 320rpx;
  margin: 20rpx 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.banner-img {
  width: 100%;
  height: 100%;
}

/* 广告位占位样式 */
.banner-ad-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #07c160, #05a34e);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.banner-ad-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  letter-spacing: 4rpx;
}



.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 30rpx 30rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.5));
}

.banner-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}

.banner-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 6rpx;
  display: block;
}

/* 快捷分类 */
.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 24rpx 10rpx;
  background: #fff;
  margin: 0 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 8rpx;
}

.quick-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.quick-label {
  font-size: 24rpx;
  color: #666;
}

/* 推荐标题 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 30rpx 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.section-more {
  font-size: 26rpx;
  color: #07c160;
}

/* 商品网格 */
.item-list {
  display: flex;
  flex-wrap: wrap;
  padding: 0 10rpx 30rpx;
}

.item-card {
  width: 50%;
  box-sizing: border-box;
  padding: 10rpx;
  margin-bottom: 10rpx;
  background: transparent;
}

.item-card-inner {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  position: relative;
}

.item-card:active {
  opacity: 0.9;
}

.item-image {
  width: 100%;
  height: 340rpx;
  background: #f0f0f0;
}

.item-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background: rgba(7, 193, 96, 0.9);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.item-info {
  padding: 18rpx 20rpx 22rpx;
}

.item-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
}

.item-meta {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-top: 12rpx;
}

.item-price {
  font-size: 34rpx;
  color: #f60;
  font-weight: 700;
}

.item-time {
  font-size: 22rpx;
  color: #bbb;
}

.load-more {
  text-align: center;
  padding: 30rpx;
  color: #bbb;
  font-size: 26rpx;
}

/* 错误状态 */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.error-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

/* ===== 公告弹窗 ===== */
.announcement-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.announcement-modal {
  width: 600rpx;
  max-height: 70vh;
  background: #fff;
  border-radius: 28rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.announcement-header {
  padding: 36rpx 32rpx 16rpx;
  text-align: center;
}

.announcement-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  display: block;
}

.announcement-time {
  font-size: 22rpx;
  color: #bbb;
  display: block;
  margin-top: 8rpx;
}

.announcement-body {
  padding: 16rpx 32rpx 32rpx;
  overflow-y: auto;
  flex: 1;
}

.announcement-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  white-space: pre-wrap;
}

.announcement-footer {
  padding: 20rpx 32rpx 36rpx;
  text-align: center;
}

.announcement-btn {
  background: linear-gradient(135deg, #07c160, #05a34e);
  color: #fff;
  border-radius: 50rpx;
  padding: 22rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.25);
}

.announcement-btn:active { opacity: 0.9; }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}
