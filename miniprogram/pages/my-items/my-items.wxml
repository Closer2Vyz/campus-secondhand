<!-- 我的发布 -->
<view class="page {{darkMode ? 'dark-mode' : ''}}">
  <view class="tabs">
    <view class="tab {{activeTab === 'active' ? 'active' : ''}}" bindtap="switchTab" data-tab="active">在售</view>
    <view class="tab {{activeTab === 'sold' ? 'active' : ''}}" bindtap="switchTab" data-tab="sold">已售</view>
    <view class="tab {{activeTab === 'inactive' ? 'active' : ''}}" bindtap="switchTab" data-tab="inactive">已下架</view>
  </view>

  <view class="list">
    <view class="list-item" wx:for="{{items}}" wx:key="id">
      <image class="list-img" src="{{item.images && item.images.length > 0 ? item.images[0] : '/assets/placeholder.png'}}" mode="aspectFill" />
      <view class="list-info">
        <text class="list-title">{{item.title}}</text>
        <text class="list-price">{{formatPrice(item.price)}}</text>
        <text class="list-status tag-{{item.status}}">{{itemStatusText(item.status)}}</text>
      </view>
      <view class="list-actions">
        <button class="action-btn" wx:if="{{activeTab === 'active'}}" bindtap="onSoldIt" data-id="{{item.id}}">标记已售</button>
        <button class="action-btn danger" wx:if="{{activeTab !== 'active'}}" bindtap="onDeleteItem" data-id="{{item.id}}">🗑️ 删除</button>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{items.length === 0}}">
    <text>暂无商品</text>
  </view>
</view>
