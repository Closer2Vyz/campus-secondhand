/* ===== 个人中心 ===== */

/* 登录卡片 */
.login-section {
  display: flex;
  justify-content: center;
  padding: 100rpx 0 60rpx;
}

.login-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 60rpx 50rpx 50rpx;
  text-align: center;
  width: 76%;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.06);
}

.login-logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07c160, #06ad56);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
}

.login-emoji { font-size: 56rpx; }

.login-title {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 12rpx;
}

.login-desc {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.login-btn {
  background: linear-gradient(135deg, #07c160, #05a34e);
  color: #fff;
  border-radius: 50rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3);
}

.login-btn:active { opacity: 0.9; }
.btn-icon { font-size: 32rpx; }

.mock-section { margin-top: 30rpx; }
.mock-toggle {
  font-size: 24rpx;
  color: #bbb;
}

.mock-login { margin-top: 30rpx; }
.mock-input {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 22rpx 28rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

.mock-btn {
  background: #f0f0f0;
  color: #666;
  border-radius: 40rpx;
  padding: 18rpx 0;
  font-size: 28rpx;
  width: 100%;
  border: none;
  margin-bottom: 12rpx;
}

/* 已登录头部 */
.profile-header {
  position: relative;
  padding: 60rpx 30rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.profile-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 240rpx;
  background: linear-gradient(135deg, #07c160, #05a34e, #048a3f);
  border-radius: 0 0 40rpx 40rpx;
}

.profile-avatar {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255,255,255,0.5);
}

.avatar-text {
  color: #fff;
  font-size: 48rpx;
  font-weight: 700;
}

.profile-info { position: relative; flex: 1; }
.profile-name { font-size: 36rpx; color: #fff; font-weight: 700; display: block; }
.profile-campus { font-size: 26rpx; color: rgba(255,255,255,0.8); margin-top: 8rpx; display: block; }

/* 菜单卡片 */
.menu-card {
  background: #fff;
  border-radius: 24rpx;
  margin: 20rpx 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  gap: 20rpx;
  border-bottom: 2rpx solid #f8f8f8;
}

.menu-item:last-child { border: none; }

.menu-icon-box {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.green { background: #e8f5e9; }
.orange { background: #fff3e0; }
.blue { background: #e3f2fd; }
.purple { background: #f3e5f5; }

.menu-texts { flex: 1; }
.menu-text { font-size: 28rpx; color: #333; font-weight: 500; display: block; }
.menu-desc { font-size: 22rpx; color: #bbb; margin-top: 4rpx; display: block; }

.menu-arrow { font-size: 36rpx; color: #ddd; }
.menu-value {
  font-size: 28rpx;
  color: #07c160;
  font-weight: 600;
  background: #e8f5e9;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
}

/* 退出 */
.logout-card {
  text-align: center;
  margin: 24rpx 24rpx;
  padding: 28rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}

.logout-text {
  font-size: 28rpx;
  color: #ff4d4f;
}
