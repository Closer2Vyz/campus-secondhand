page { background: #f8f8f8; }

.seller-header {
  background: linear-gradient(135deg, #07c160, #05a34e);
  padding: 60rpx 0 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.seller-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  margin-bottom: 16rpx;
  border: 4rpx solid rgba(255,255,255,0.3);
}

.seller-avatar image {
  width: 100%;
  height: 100%;
}

.seller-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}

.seller-campus {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  display: block;
  margin-top: 8rpx;
}

.seller-rating {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
}

.rating-stars {
  font-size: 28rpx;
  color: #ffc107;
}

.rating-count {
  font-size: 24rpx;
  color: rgba(255,255,255,0.75);
}

.seller-since {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
  display: block;
  margin-top: 8rpx;
}

.section-header {
  padding: 30rpx 30rpx 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.item-list {
  display: flex;
  flex-wrap: wrap;
  padding: 0 10rpx 30rpx;
}

.item-card {
  width: 50%;
  box-sizing: border-box;
  padding: 10rpx;
}

.item-card-inner {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.item-image {
  width: 100%;
  height: 300rpx;
  background: #f0f0f0;
}

.item-info {
  padding: 16rpx 20rpx 20rpx;
}

.item-title {
  font-size: 26rpx;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
}

.item-price {
  font-size: 32rpx;
  color: #f60;
  font-weight: 700;
  display: block;
  margin-top: 8rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}
