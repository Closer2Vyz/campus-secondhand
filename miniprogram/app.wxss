/* ===== 全局样式 ===== */
page {
  background-color: #f8f8f8;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC', sans-serif;
  color: #333;
  box-sizing: border-box;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 20rpx;
  margin: 16rpx 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, #07c160, #05a34e);
  color: #fff;
  border-radius: 50rpx;
  padding: 22rpx 40rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.25);
}

.btn-primary:active { opacity: 0.9; }

.btn-secondary {
  background: #fff;
  color: #07c160;
  border: 2rpx solid #07c160;
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  font-size: 28rpx;
}

/* 输入框 */
.input-group {
  margin-bottom: 28rpx;
}

.input-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
  font-weight: 500;
}

.input-field {
  width: 100%;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
  transition: all 0.2s;
}

.input-field:focus {
  border-color: #07c160;
  background: #fff;
  box-shadow: 0 0 0 4rpx rgba(7, 193, 96, 0.1);
}

/* 状态标签 */
.tag-pending {
  background: #fff7e6;
  color: #fa8c16;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.tag-completed {
  background: #e8f5e9;
  color: #07c160;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.tag-cancelled {
  background: #fff0f0;
  color: #ff4d4f;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.4;
}